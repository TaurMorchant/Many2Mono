# =============================================================================
# Many2Mono Configuration
# =============================================================================
# Copy this file to 'config.env' and fill in the values.
# Lines starting with '#' are comments.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Maven coordinates for the monorepo
# -----------------------------------------------------------------------------

# Maven groupId for the monorepo (e.g., com.mycompany.platform)
MONOREPO_GROUP_ID=

# Maven artifactId for the monorepo (e.g., my-platform)
MONOREPO_ARTIFACT_ID=

# Monorepo version (default: 1.0.0-SNAPSHOT)
#MONOREPO_VERSION=1.0.0-SNAPSHOT

# -----------------------------------------------------------------------------
# REQUIRED: GitHub repository information
# Used for SCM, distribution management, and repository URLs
# -----------------------------------------------------------------------------

# GitHub organization or user name
GITHUB_ORG=

# GitHub repository name
GITHUB_REPO=

# -----------------------------------------------------------------------------
# OPTIONAL: Output directory
# -----------------------------------------------------------------------------

# Directory name for the generated monorepo (default: monorepo)
#MONOREPO_DIR_NAME=monorepo

# -----------------------------------------------------------------------------
# OPTIONAL: Versions (defaults provided)
# Uncomment and modify if you need different values
# -----------------------------------------------------------------------------

# Java compiler version (default: 17)
#JAVA_VERSION=17

# Lombok version for annotation processor (default: 1.18.42)
#LOMBOK_VERSION=1.18.42

# -----------------------------------------------------------------------------
# OPTIONAL: Git branches to process
# -----------------------------------------------------------------------------

# Space-separated list of branches to clone and merge (default: main)
# For LTS support, include LTS branches: main lts/25.3 lts/25.4
#BRANCHES=main
